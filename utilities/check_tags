#!/usr/bin/env ruby
# frozen_string_literal: true

require 'yaml'
require 'optparse'

POST_DIRS = %w[blog notes replies exercise].freeze

def extract_tags(yaml_content)
  return [] unless yaml_content.is_a?(Hash)

  tags = yaml_content['tags']
  return [] unless tags

  if tags.is_a?(Array)
    tags.map(&:to_s)
  else
    tags.to_s.split(/\s+/)
  end
end

def front_matter(content)
  return nil unless content =~ /\A(---\s*\n.*?\n?)^((---|\.\.\.)\s*$\n?)/m

  YAML.safe_load(::Regexp.last_match(1), permitted_classes: [Date, Time, DateTime, Symbol])
rescue Psych::SyntaxError
  nil
end

def bad_tags_in(file_path)
  return [] unless File.exist?(file_path)

  yaml = front_matter(File.read(file_path))
  extract_tags(yaml).reject { |t| t == t.downcase }
end

def candidate_files(staged_only:)
  if staged_only
    `git diff --cached --name-only --diff-filter=ACM`.split("\n").select { |f| f.end_with?('.md') }
  else
    Dir.glob(POST_DIRS.map { |d| "#{d}/**/*.md" })
  end
end

options = { staged: false }
OptionParser.new do |opts|
  opts.banner = 'Usage: check_tags [--staged]'
  opts.on('--staged', 'Check only git-staged files') { options[:staged] = true }
end.parse!

violations = candidate_files(staged_only: options[:staged]).filter_map do |path|
  bad = bad_tags_in(path)
  [path, bad] unless bad.empty?
end

if violations.empty?
  exit 0
end

violations.each do |path, bad|
  warn "#{path}: #{bad.join(', ')}"
end
warn ''
warn "Found #{violations.size} file(s) with non-lowercase tags. Tags must be lowercase per CLAUDE.md."
exit 1
